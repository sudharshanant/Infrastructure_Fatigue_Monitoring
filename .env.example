# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-os-urandom

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=4

# Data Configuration
DATA_PATH=data/vibration_data.csv

# Monitoring Thresholds
SAFE_THRESHOLD=0.22
WARNING_THRESHOLD=0.30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS (if needed for external API access)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
